‚Äč‚Äč
‚Äč‚Äč                curMinutes = Math.floor(audio.currentTime / 60);
‚Äč‚Äč                curSeconds = Math.floor(audio.currentTime - curMinutes * 60);
‚Äč‚Äč                
‚Äč‚Äč                durMinutes = Math.floor(audio.duration / 60);
‚Äč‚Äč                durSeconds = Math.floor(audio.duration - durMinutes * 60);
‚Äč‚Äč                
‚Äč‚Äč                playProgress = (audio.currentTime / audio.duration) * 100;
‚Äč‚Äč                
‚Äč‚Äč                if(curMinutes < 10)
‚Äč‚Äč                        curMinutes = '0'+curMinutes;
‚Äč‚Äč                if(curSeconds < 10)
‚Äč‚Äč                        curSeconds = '0'+curSeconds;
‚Äč‚Äč                
‚Äč‚Äč                if(durMinutes < 10)
‚Äč‚Äč                        durMinutes = '0'+durMinutes;
‚Äč‚Äč                if(durSeconds < 10)
‚Äč‚Äč                        durSeconds = '0'+durSeconds;
‚Äč‚Äč        
‚Äč‚Äč        if( isNaN(curMinutes) || isNaN(curSeconds) )
‚Äč‚Äč            tProgress.text('00:00');
‚Äč‚Äč        else
‚Äč‚Äč                    tProgress.text(curMinutes+':'+curSeconds);
‚Äč‚Äč        
‚Äč‚Äč        if( isNaN(durMinutes) || isNaN(durSeconds) )
‚Äč‚Äč            tTime.text('00:00');
‚Äč‚Äč        else
‚Äč‚Äč                    tTime.text(durMinutes+':'+durSeconds);
‚Äč‚Äč        
‚Äč‚Äč        if( isNaN(curMinutes) || isNaN(curSeconds) || isNaN(durMinutes) || isNaN(durSeconds) )
‚Äč‚Äč            trackTime.removeClass('active');
‚Äč‚Äč        else
‚Äč‚Äč            trackTime.addClass('active');
‚Äč‚Äč
‚Äč‚Äč        
‚Äč‚Äč                seekBar.width(playProgress+'%');
‚Äč‚Äč                
‚Äč‚Äč                if( playProgress == 100 )
‚Äč‚Äč                {
‚Äč‚Äč                        i.attr('class','fa fa-play');
‚Äč‚Äč                        seekBar.width(0);
‚Äč‚Äč            tProgress.text('00:00');
‚Äč‚Äč            albumArt.removeClass('buffering').removeClass('active');
‚Äč‚Äč            clearInterval(buffInterval);
‚Äč‚Äč                }
‚Äč‚Äč    }
‚Äč‚Äč    
‚Äč‚Äč    function checkBuffering()
‚Äč‚Äč    {
‚Äč‚Äč        clearInterval(buffInterval);
‚Äč‚Äč        buffInterval = setInterval(function()
‚Äč‚Äč        { 
‚Äč‚Äč            if( (nTime == 0) || (bTime - nTime) > 1000  )
‚Äč‚Äč                albumArt.addClass('buffering');
‚Äč‚Äč            else
‚Äč‚Äč                albumArt.removeClass('buffering');
‚Äč‚Äč
‚Äč‚Äč            bTime = new Date();
‚Äč‚Äč            bTime = bTime.getTime();
‚Äč‚Äč
‚Äč‚Äč        },100);
‚Äč‚Äč    }
‚Äč‚Äč
‚Äč‚Äč    function selectTrack(flag)
‚Äč‚Äč    {
‚Äč‚Äč        if( flag == 0 || flag == 1 )
‚Äč‚Äč            ++currIndex;
‚Äč‚Äč        else
‚Äč‚Äč            --currIndex;
‚Äč‚Äč
‚Äč‚Äč        if( (currIndex > -1) && (currIndex < albumArtworks.length) )
‚Äč‚Äč        {
‚Äč‚Äč            if( flag == 0 )
‚Äč‚Äč                i.attr('class','fa fa-play');
‚Äč‚Äč            else
‚Äč‚Äč            {
‚Äč‚Äč                albumArt.removeClass('buffering');
‚Äč‚Äč                i.attr('class','fa fa-pause');
‚Äč‚Äč            }
‚Äč‚Äč
‚Äč‚Äč            seekBar.width(0);
‚Äč‚Äč            trackTime.removeClass('active');
‚Äč‚Äč            tProgress.text('00:00');
‚Äč‚Äč            tTime.text('00:00');
‚Äč‚Äč
‚Äč‚Äč            currAlbum = albums[currIndex];
‚Äč‚Äč            currTrackName = trackNames[currIndex];
‚Äč‚Äč            currArtwork = albumArtworks[currIndex];
‚Äč‚Äč
‚Äč‚Äč            audio.src = trackUrl[currIndex];
‚Äč‚Äč            
‚Äč‚Äč            nTime = 0;
‚Äč‚Äč            bTime = new Date();
‚Äč‚Äč            bTime = bTime.getTime();
‚Äč‚Äč
‚Äč‚Äč            if(flag != 0)
‚Äč‚Äč            {
‚Äč‚Äč                audio.play();
‚Äč‚Äč                playerTrack.addClass('active');
‚Äč‚Äč                albumArt.addClass('active');
‚Äč‚Äč            
‚Äč‚Äč                clearInterval(buffInterval);
‚Äč‚Äč                checkBuffering();
‚Äč‚Äč            }
‚Äč‚Äč
‚Äč‚Äč            albumName.text(currAlbum);
‚Äč‚Äč            trackName.text(currTrackName);
‚Äč‚Äč            albumArt.find('img.active').removeClass('active');
‚Äč‚Äč            $('#'+currArtwork).addClass('active');
‚Äč‚Äč            
‚Äč‚Äč            
‚Äč‚Äč        }
‚Äč‚Äč        else
‚Äč‚Äč        {
‚Äč‚Äč            if( flag == 0 || flag == 1 )
‚Äč‚Äč                --currIndex;
‚Äč‚Äč            else
‚Äč‚Äč                ++currIndex;
‚Äč‚Äč        }
‚Äč‚Äč    }
‚Äč‚Äč
‚Äč‚Äč    function initPlayer()
‚Äč‚Äč        {        
‚Äč‚Äč        audio = new Audio();
‚Äč‚Äč
‚Äč‚Äč                selectTrack(0);
‚Äč‚Äč                
‚Äč‚Äč                audio.loop = false;
‚Äč‚Äč                
‚Äč‚Äč                playPauseButton.on('click',playPause);
‚Äč‚Äč                
‚Äč‚Äč                sArea.mousemove(function(event){ showHover(event); });
‚Äč‚Äč                
‚Äč‚Äč        sArea.mouseout(hideHover);
‚Äč‚Äč        
‚Äč‚Äč        sArea.on('click',playFromClickedPos);
‚Äč‚Äč                
‚Äč‚Äč        $(audio).on('timeupdate',updateCurrTime);
‚Äč‚Äč
‚Äč‚Äč        playPreviousTrackButton.on('click',function(){ selectTrack(-1);} );
‚Äč‚Äč        playNextTrackButton.on('click',function(){ selectTrack(1);});
‚Äč‚Äč        }
‚Äč‚Äč    
‚Äč‚Äč        initPlayer();
‚Äč‚Äč});
‚Äč‚Äč  </script>
